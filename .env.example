# AI providers (server-side only, never exposed to the browser)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Demo mode: "true" = deterministic mock AI responses, no external API calls
NEXT_PUBLIC_DEMO_MODE=true

# API and local PostgreSQL (used by `docker compose up`)
POSTGRES_ADMIN_USER=insightops_admin
POSTGRES_ADMIN_PASSWORD=insightops_admin
POSTGRES_MIGRATOR_PASSWORD=insightops_migrator
POSTGRES_APP_PASSWORD=insightops_app
APP_DATABASE_ROLE=insightops_app
APP_DATABASE_URL=postgresql://insightops_app:insightops_app@localhost:5432/insightops?schema=public
MIGRATION_DATABASE_URL=postgresql://insightops_migrator:insightops_migrator@localhost:5432/insightops?schema=public
DATABASE_URL=postgresql://insightops_app:insightops_app@localhost:5432/insightops?schema=public
API_PORT=4000
LOG_LEVEL=info
