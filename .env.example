# AI providers (server-side only, never exposed to the browser)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Demo mode: "true" = deterministic mock AI responses, no external API calls
NEXT_PUBLIC_DEMO_MODE=true
NEXT_PUBLIC_DATA_SOURCE=api
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:4000/v1

# Local Docker Compose only. Replace every password before first startup.
POSTGRES_DB=insightops
POSTGRES_ADMIN_USER=insightops_admin
POSTGRES_ADMIN_PASSWORD=replace-with-random-admin-password
POSTGRES_MIGRATOR_USER=insightops_migrator
POSTGRES_MIGRATOR_PASSWORD=replace-with-random-migrator-password
POSTGRES_APP_USER=insightops_app
POSTGRES_APP_PASSWORD=replace-with-random-app-password

# Compose URLs use the service hostname. URL-encode passwords containing reserved characters.
APP_DATABASE_URL=postgresql://insightops_app:replace-with-url-encoded-app-password@postgres:5432/insightops?schema=public
MIGRATION_DATABASE_URL=postgresql://insightops_migrator:replace-with-url-encoded-migrator-password@postgres:5432/insightops?schema=public

# Host URL for local Prisma commands (not passed to Compose).
DATABASE_URL=postgresql://insightops_app:replace-with-url-encoded-app-password@127.0.0.1:5432/insightops?schema=public
FRONTEND_PORT=3000
API_PORT=4000
POSTGRES_PORT=5432
LOG_LEVEL=debug

# Required by production Compose, for example https://api.example.com/v1.
# PUBLIC_API_BASE_URL=https://api.example.com/v1
# CORS_ALLOWED_ORIGINS=https://app.example.com

# Production Compose: absolute paths to files stored outside this repository.
# APP_DATABASE_URL_SECRET_FILE=/run/insightops-secrets/app-database-url
# MIGRATION_DATABASE_URL_SECRET_FILE=/run/insightops-secrets/migration-database-url
# POSTGRES_ADMIN_PASSWORD_SECRET_FILE=/run/insightops-secrets/postgres-admin-password
# POSTGRES_MIGRATOR_PASSWORD_SECRET_FILE=/run/insightops-secrets/postgres-migrator-password
# POSTGRES_APP_PASSWORD_SECRET_FILE=/run/insightops-secrets/postgres-app-password
